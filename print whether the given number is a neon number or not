#include<iostream>
using namespace std;

int neon(int num) 
{
    int square, sum_of_digits = 0;
    square = num * num;  
    while(square != 0) { 
        sum_of_digits += (square % 10);  
        square /= 10;  
    }
    return (sum_of_digits == num);  
}

int main()
{
    int num;
    cin >> num;  
    if(neon(num))  
        cout << num << " is a neon number";
    else
        cout << num << " is not a neon number";  
    return 0;
}
